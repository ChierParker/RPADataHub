# ============================================================
# EcomIQ — 统一 .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual Environment
.venv/
venv/

# Dependencies
node_modules/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# Secrets & Local Config
.env
.env.local
.env.*.local
*.key
*.pem
settings.local.json
amazon_cookies.json
Login_log/

# Runtime Data (per-module)
logs/
output/
input/
debug/
uploads/
tmp/
temp/
cache/

# User / Session Data (may contain cookies & sensitive info)
profiles/
sessions/
cookies/
browser/
*.local.*
*.private.*

# Database (runtime SQLite)
*.db
*.sqlite
*.sqlite3

# RPA Specific
rpa_output/
rpa_archive/
rpa_fallback/
artifacts/

# Build Artifacts
build/
dist/
*.spec
*.exe
.next/
out/

# Generated / Temp
_gen_*.py
_fix_*.py
_build_*.py
start_admin_silent.vbs
*.bak

# Playwright
playwright-report/
test-results/
