# ============================================================
# EcomIQ-RPA 生产环境配置模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# 数据库
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=ecomiq
DB_PASSWORD=your-production-password
DB_NAME=data

# Redis（可选，不配则降级 DB 轮询）
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# Flask 安全
ECOMIQ_RPA_SECRET_KEY=change-me-to-random-64-char-string
SESSION_COOKIE_SECURE=True

# DeepSeek AI（可选）
DEEPSEEK_API_KEY=sk-your-key

# RPA Worker
RPA_WORKER_MODE=direct
RPA_TASK_TIMEOUT=3600

# 日志
LOG_LEVEL=INFO
LOG_DIR=./logs
