# RPADataHub 环境变量配置
# 复制此文件为 .env 并填入你的实际值
# 所有环境变量均使用 RPA_ 前缀

# ============================================================
# MySQL 数据库
# ============================================================
RPA_DB_HOST=localhost
RPA_DB_PORT=3306
RPA_DB_USER=root
RPA_DB_PASSWORD=your-db-password
RPA_DB_DATABASE=data

# ============================================================
# DeepSeek AI API
# ============================================================
RPA_DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================================
# Redis (可选, 不配则自动降级DB轮询)
# ============================================================
RPA_REDIS_URL=redis://:your-redis-password@localhost:6379

# ============================================================
# Flask 安全密钥 (生产环境务必修改为随机字符串)
# ============================================================
RPA_FLASK_SECRET_KEY=your-random-secret-key-at-least-24-chars

# ============================================================
# Bark 告警推送 (可选)
# ============================================================
RPA_BARK_URL=https://api.day.app/your-bark-key

# ============================================================
# 文件监听路径
# ============================================================
RPA_WATCH_FOLDER=D:/rpa_output
RPA_ARCHIVE_FOLDER=D:/rpa_archive
RPA_LOG_DIR=D:/RPADataHub/rpa_logs
RPA_FALLBACK_DIR=D:/rpa_fallback

# ============================================================
# 可选：钉钉/企业微信 Webhook
# ============================================================
# RPA_DINGTALK_WEBHOOK=
# RPA_WECHAT_WEBHOOK=
