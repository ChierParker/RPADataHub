# EcomIQ-RPA 环境变量配置模板
# 复制此文件为 .env 并填入你的实际值
# 所有环境变量均使用 RPA_ 前缀
# 注意: .env 已在 .gitignore 中，不会被提交到 Git

# ============================================================
# MySQL 数据库
# ============================================================
RPA_DB_HOST=localhost
RPA_DB_PORT=3306
RPA_DB_USER=root
RPA_DB_PASSWORD=your-database-password
RPA_DB_DATABASE=data

# ============================================================
# DeepSeek AI API
# ============================================================
RPA_DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ============================================================
# Redis (可选, 不配则自动降级DB轮询)
# ============================================================
RPA_REDIS_URL=redis://:password@localhost:6379

# ============================================================
# Flask 安全密钥 (生产环境务必修改为随机字符串)
# ============================================================
RPA_FLASK_SECRET_KEY=change-me-to-random-string

# ============================================================
# Bark 告警推送 (可选)
# ============================================================
RPA_BARK_URL=https://api.day.app/your-bark-key

# ============================================================
# 文件监听路径
# ============================================================
RPA_WATCH_FOLDER=D:/rpa_output
RPA_ARCHIVE_FOLDER=D:/rpa_archive
RPA_LOG_DIR=D:/EcomIQ-RPA/rpa_logs
RPA_FALLBACK_DIR=D:/rpa_fallback

# ============================================================
# 可选：钉钉/企业微信 Webhook
# ============================================================
# RPA_DINGTALK_WEBHOOK=
# RPA_WECHAT_WEBHOOK=
