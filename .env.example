# RPADataHub 环境变量配置
# 复制此文件为 .env 并填入你的实际值

# MySQL 数据库
RPA_DB_HOST=localhost
RPA_DB_PORT=3306
RPA_DB_USER=root
RPA_DB_PASSWORD=YOUR_MYSQL_PASSWORD
RPA_DB_DATABASE=data

# DeepSeek AI API
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# Redis (可选, 不配则自动降级DB轮询)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379

# Bark 告警推送 (可选)
RPA_BARK_URL=https://api.day.app/YOUR_BARK_KEY

# 文件监听路径
RPA_WATCH_FOLDER=D:/rpa_output
RPA_ARCHIVE_FOLDER=D:/rpa_archive
RPA_LOG_DIR=D:/RPADataHub/rpa_logs
